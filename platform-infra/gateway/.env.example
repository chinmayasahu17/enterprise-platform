# Ports
SERVER_PORT=8080
MANAGEMENT_PORT=8081

# Redis (rate limiting)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (dev-only token flow, see AuthController)
JWT_SECRET=change-me-to-a-random-32-byte-string
JWT_TTL_SECONDS=3600

# Downstream service URLs - in Kubernetes these become the ClusterIP Service
# DNS names, e.g. http://ingestion-service:8080
INGESTION_SERVICE_URL=http://localhost:8180
PROCESSING_SERVICE_URL=http://localhost:8181
NOTIFICATION_SERVICE_URL=http://localhost:8182
REPORT_SERVICE_URL=http://localhost:8183
ANALYTICS_SQLCLIENT_URL=http://localhost:8184
